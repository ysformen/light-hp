      <p class="footer-hours">24時間365日対応</p>
    </div>
    <div class="footer-links">
      <h4>サービス</h4>
      <ul>
        <li><a href="#plans">家族葬</a></li>
        <li><a href="#plans">一般葬</a></li>
        <li><a href="#plans">直葬・火葬式</a></li>
        <li><a href="#venues">式場案内</a></li>
      </ul>
    </div>
    <div class="footer-links">
      <h4>ご案内</h4>
      <ul>
        <li><a href="#flow">ご葬儀の流れ</a></li>
        <li><a href="#pricing">料金案内</a></li>
        <li><a href="#faq">よくある質問</a></li>
        <li><a href="#contact">お問い合わせ</a></li>
