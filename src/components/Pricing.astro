---
const items = [
  { category: '基本費用', name: 'お棺、ご遺影額・加工料含', price: '含む' },
  { category: '基本費用', name: '企画・運営各スタッフ料', price: '含む' },
  { category: '基本費用', name: '遺影写真制作', price: '含む' },
  { category: '基本費用', name: '一回分ドライアイス', price: '含む' },
  { category: '基本費用', name: '納棺花30本', price: '含む' },
  { category: '基本費用', name: '火葬手続き代行', price: '含む' },
  { category: '基本費用', name: '白木位牌塔婆一式', price: '含む' },
  { category: '基本費用', name: '枕飾り後祭壇', price: '含む' },
  { category: '基本費用', name: '霊供膳一式', price: '含む' },
  { category: '基本費用', name: '看板類筆記用具', price: '含む' },
  { category: '基本費用', name: '法事・相続アフターフォロー', price: '含む' },
  { category: '別途費用', name: '搬送車・霊柩車', price: '実費' },
  { category: '別途費用', name: '返礼品', price: '実費' },
  { category: '別途費用', name: '弁当・お料理', price: '実費' },
  { category: '別途費用', name: 'その他オプション', price: '実費' },
];

const categories = [...new Set(items.map(i => i.category))];
---

<section class="pricing" id="pricing">
  <div class="inner">
    <p class="section-subtitle">PRICING</p>
    <h2 class="section-title">料金案内</h2>
    <div class="section-divider"></div>

    <div class="pricing-note">
      <p>明朗会計を徹底しています。事前にすべての費用をご説明し、追加費用が発生することはありません。</p>
      <p style="margin-top:0.5rem; font-size:0.8rem;">※ 表示価格はすべて税込みです。</p>
    </div>

    <div class="pricing-table-wrap">
      <table class="pricing-table">
        <thead>
          <tr>
            <th>項目</th>
            <th>内容</th>
            <th>費用</th>
          </tr>
        </thead>
        <tbody>
          {categories.map(cat => (
            <>
              <tr class="category-row">
                <td colspan="3">{cat}</td>
              </tr>
              {items.filter(i => i.category === cat).map(item => (
                <tr>
                  <td></td>
                  <td>{item.name}</td>
                  <td class={item.price === '含む' ? 'price-included' : item.price === '実費' ? 'price-actual' : 'price-amount'}>
                    {item.price}
                  </td>
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
    </div>

    <div class="pricing-summary">
      <div class="summary-card">
        <p class="summary-label">一日葬プラン</p>
        <p class="summary-price">¥195,000</p>
        <p class="summary-note">告別式・火葬を一日で執り行い</p>
      </div>
      <div class="summary-card highlight">
        <p class="summary-label">一般葬プラン</p>
        <p class="summary-price">¥275,000</p>
        <p class="summary-note">通夜・告別式・火葬込み</p>
      </div>
      <div class="summary-card">
        <p class="summary-label">火葬式プラン</p>
        <p class="summary-price">¥55,000</p>
        <p class="summary-note">シンプルに火葬のみ</p>
      </div>
    </div>

    <p class="pricing-cta-text">詳細なお見積りは無料です。お気軽にご相談ください。</p>
    <div style="text-align:center">
      <a href="tel:050-8895-3811" class="btn-primary">無料でお見積りを依頼する</a>
    </div>
  </div>
</section>

<style>
  .pricing {
    padding: 6rem 1.5rem;
    background: var(--color-bg-soft);
  }

  .inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .pricing-note {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.9rem;
    line-height: 2;
    margin-bottom: 2.5rem;
  }

  .pricing-table-wrap {
    overflow-x: auto;
    margin-bottom: 3rem;
    background: #fff;
    border-radius: 2px;
  }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .pricing-table thead th {
    background: var(--color-primary);
    color: #fff;
    font-weight: 500;
    padding: 0.75rem 1rem;
    text-align: left;
    letter-spacing: 0.08em;
  }

  .pricing-table tbody tr {
    border-bottom: 1px solid var(--color-border);
  }

  .pricing-table tbody td {
    padding: 0.65rem 1rem;
    color: var(--color-text);
  }

  .category-row td {
    background: var(--color-bg-soft);
    color: var(--color-primary) !important;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    font-weight: 500;
    padding: 0.5rem 1rem !important;
  }

  .price-included { color: var(--color-accent) !important; font-weight: 500; }
  .price-actual { color: var(--color-text-light) !important; }
  .price-amount { color: var(--color-primary-dark) !important; font-weight: 500; }

  .pricing-summary {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .summary-card {
    background: #fff;
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    text-align: center;
  }

  .summary-card.highlight {
    border-color: var(--color-primary);
    border-width: 2px;
  }

  .summary-label {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .summary-price {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-primary-dark);
    letter-spacing: 0.02em;
    margin-bottom: 0.5rem;
  }

  .summary-note {
    font-size: 0.72rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .pricing-cta-text {
    text-align: center;
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 700px) {
    .pricing-summary { grid-template-columns: 1fr; }
  }
</style>
