---
const items = [
  { file: '霊柩車', label: '霊柩車', ext: 'png' },
  { file: '返礼品', label: '返礼品', ext: 'png' },
  { file: '弁当・お料理', label: '弁当・お料理', ext: 'png' },
  { file: '受付', label: '受付', ext: 'png' },
];
---

<section class="options">
  <div class="inner">
    <p class="section-subtitle">OPTIONS</p>
    <h2 class="section-title">オプション</h2>
    <div class="section-divider"></div>
    <p class="options-note">生花・受付代行などご要望に合わせたオプションをご提案いたします。</p>
    <div class="options-grid">
      {items.map(item => (
        <div class="option-item">
          <div class="option-icon-wrap">
            <img
              src={`/images/icons/${encodeURIComponent(item.file)}.${item.ext ?? 'jpg'}`}
              alt={item.label}
              class="option-icon"
            />
          </div>
          <p class="option-label">{item.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .options {
    padding: 5rem 1.5rem;
    background: var(--color-bg-soft);
  }

  .inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .options-note {
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 3rem;
  }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .option-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    transition: box-shadow 0.2s;
  }

  .option-item:hover {
    box-shadow: 0 4px 16px rgba(61, 122, 138, 0.1);
  }

  .option-icon-wrap {
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .option-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .option-label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary-dark);
    letter-spacing: 0.05em;
  }

  @media (max-width: 700px) {
    .options-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
