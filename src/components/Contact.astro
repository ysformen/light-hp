---
---

<section class="contact" id="contact">
  <div class="inner">
    <p class="section-subtitle">CONTACT</p>
    <h2 class="section-title">お問い合わせ</h2>
    <div class="section-divider"></div>

    <div class="contact-wrap">
      <div class="contact-info">
        <h3 class="contact-info-title">お電話でのご相談</h3>
        <a href="tel:050-8895-3811" class="contact-tel">050-8895-3811</a>
        <p class="contact-hours">24時間 · 365日対応</p>
        <p class="contact-info-desc">
          急なご逝去の際もすぐにご連絡ください。<br />
          経験豊富なスタッフが迅速に対応いたします。
        </p>
        <div class="contact-address">
          <p class="contact-address-label">所在地</p>
          <p>〠426-0071<br />静岡県藤枝市志太3丁目8-2 2階</p>
        </div>
        <div class="contact-address" style="margin-top:1.2rem">
          <p class="contact-address-label">メール</p>
          <a href="mailto:shiminso-light@ii-sougi.jp" class="contact-email">shiminso-light@ii-sougi.jp</a>
        </div>
      </div>

      <form class="contact-form" action="mailto:shiminso-light@ii-sougi.jp" method="POST" enctype="text/plain">
        <div class="form-group">
          <label for="name">お名前 <span class="required">必須</span></label>
          <input type="text" id="name" name="name" required placeholder="山田 太郎" />
        </div>
        <div class="form-group">
          <label for="tel">お電話番号 <span class="required">必須</span></label>
          <input type="tel" id="tel" name="tel" required placeholder="050-8895-3811" />
        </div>
        <div class="form-group">
          <label for="email">メールアドレス</label>
          <input type="email" id="email" name="email" placeholder="example@mail.com" />
        </div>
        <div class="form-group">
          <label for="type">ご相談の種類</label>
          <select id="type" name="type">
            <option value="">選択してください</option>
            <option value="family">家族葬について</option>
            <option value="general">一般葬について</option>
            <option value="direct">直葬・火葬式について</option>
            <option value="advance">事前相談・終活について</option>
            <option value="other">その他</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">ご相談内容 <span class="required">必須</span></label>
          <textarea id="message" name="message" required rows="5" placeholder="ご不明な点やご要望をお聞かせください。"></textarea>
        </div>
        <p class="form-privacy">
          お問い合わせの内容は、<a href="#">プライバシーポリシー</a>に基づき適切に取り扱います。
        </p>
        <button type="submit" class="form-submit">送信する</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 6rem 1.5rem;
    background: var(--color-cream-dark);
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .contact-wrap {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-info-title {
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .contact-tel {
    display: block;
    font-size: 2rem;
    font-weight: 400;
    color: var(--color-primary-dark);
    text-decoration: none;
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
    transition: color 0.2s;
  }

  .contact-tel:hover { color: var(--color-primary); }

  .contact-hours {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  .contact-info-desc {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 2;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .contact-address-label {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.4rem;
  }

  .contact-address p:last-child {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.8;
  }

  .contact-email {
    font-size: 0.85rem;
    color: var(--color-primary);
    text-decoration: none;
    word-break: break-all;
  }

  .contact-email:hover {
    text-decoration: underline;
  }

  .contact-form {
    background: #fff;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    color: var(--color-primary-dark);
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .required {
    font-size: 0.65rem;
    background: var(--color-primary);
    color: #fff;
    padding: 0.15rem 0.4rem;
    letter-spacing: 0.05em;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    border: 1px solid var(--color-border);
    padding: 0.75rem 1rem;
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: var(--color-text);
    background: var(--color-bg-soft);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-primary);
    background: #fff;
  }

  .form-group textarea {
    resize: vertical;
  }

  .form-privacy {
    font-size: 0.75rem;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .form-privacy a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .form-submit {
    width: 100%;
    padding: 1rem;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-serif);
    font-size: 1rem;
    letter-spacing: 0.15em;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .form-submit:hover {
    background: var(--color-primary-light);
  }

  @media (max-width: 800px) {
    .contact-wrap { grid-template-columns: 1fr; gap: 2.5rem; }
    .contact-form { padding: 1.5rem; }
  }
</style>
