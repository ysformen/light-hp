---
const items = [
  { file: '枕飾り後祭壇', label: '枕飾り・後祭壇', desc: '', ext: 'png' },
  { file: 'ドライアイス', label: '一回分のドライアイス', desc: '', ext: 'png' },
  { file: '棺', label: '棺一式', desc: '納棺・ご安置', ext: 'png' },
  { file: '遺影', label: '遺影', desc: '遺影写真の作成（額付き）', ext: 'png' },
  { file: '位牌', label: '位牌', desc: '白木位牌<br>塔婆一式', ext: 'png' },
  { file: 'お骨甕覆いセット', label: 'お骨甕覆いセット', desc: '', ext: 'png' },
  { file: '納棺花30本', label: '納棺花30本', desc: '', ext: 'png' },
  { file: '企画・運営各スタッフ料', label: '企画・運営各スタッフ料', desc: '', scale: 1.4 },
  { file: '火葬手続き代行', label: '火葬手続き代行', desc: '', ext: 'png' },
  { file: '霊供膳一式', label: '霊供膳一式', desc: '', ext: 'png' },
  { file: '看板類・筆記用具', label: '看板類・筆記用具', desc: '' },
  { file: '法事・相続・アフターフォロー', label: '法事・相続・アフターフォロー', desc: '', ext: 'png' },
];
---

<section class="includes">
  <div class="inner">
    <p class="section-subtitle">WHAT'S INCLUDED</p>
    <h2 class="section-title">セットに含まれるもの</h2>
    <div class="section-divider"></div>
    <p class="includes-note">火葬式プランを除く全プランで、以下をすべてご用意しています。追加費用は一切かかりません。</p>
    <div class="includes-grid">
      {items.map(item => (
        <div class="include-item">
          <div class="include-icon-wrap">
            <img
              src={`/images/icons/${encodeURIComponent(item.file)}.${item.ext ?? 'jpg'}`}
              alt={item.label}
              class="include-icon"
              style={item.scale ? `transform: scale(${item.scale})` : ''}
            />
          </div>
          <p class="include-label">{item.label}</p>
          <p class="include-desc" set:html={item.desc} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .includes {
    padding: 5rem 1.5rem;
    background: var(--color-bg);
  }

  .inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .includes-note {
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-light);
    margin-bottom: 3rem;
  }

  .includes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .include-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 1rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    transition: box-shadow 0.2s;
  }

  .include-item:hover {
    box-shadow: 0 4px 16px rgba(61, 122, 138, 0.1);
  }

  .include-icon-wrap {
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .include-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .include-label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary-dark);
    margin-bottom: 0.3rem;
    letter-spacing: 0.05em;
  }

  .include-desc {
    font-size: 0.75rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .includes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 400px) {
    .includes-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }
</style>
